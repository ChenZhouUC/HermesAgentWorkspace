# ── 大模型 / LLM ──────────────────────────────────────────

# Google Gemini
GEMINI_API_KEY=your_gemini_api_key_here
GOOGLE_API_KEY=your_gemini_api_key_here  # 与 GEMINI_API_KEY 相同

# Alibaba Qwen (DashScope 国内端点)
BAILIAN_API_KEY=your_dashscope_api_key_here
DASHSCOPE_API_KEY=your_dashscope_api_key_here  # 与 BAILIAN_API_KEY 相同
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# ── 飞书 / Feishu ─────────────────────────────────────────

FEISHU_APP_ID=cli_xxxxxxxxxxxx
FEISHU_APP_SECRET=your_feishu_app_secret
FEISHU_DOMAIN=https://open.feishu.cn
FEISHU_CONNECTION_MODE=websocket
# FEISHU_ALLOWED_USERS=user_id_1,user_id_2   # 留空 + GATEWAY_ALLOW_ALL_USERS=true 更方便
# FEISHU_HOME_CHANNEL=oc_xxxxxxxxxxxx          # 可选：Bot 启动时主动发送的频道

# ── Hermes Gateway ────────────────────────────────────────

HERMES_GATEWAY_TOKEN=your_32char_random_token_here  # hermes gateway install 时自动生成

# ── Gateway 访问控制 ───────────────────────────────────────

# 个人 bot：开放全部访问（推荐）
GATEWAY_ALLOW_ALL_USERS=true
# 多用户场景：注释上一行，改用飞书用户 ID 白名单
# FEISHU_ALLOWED_USERS=ou_xxxxxxxxxxxx,ou_yyyyyyyyyyyy

# ── 可选：GitHub Token（Skills Hub 提速，避免限速）──────────

# GITHUB_TOKEN=ghp_xxxxxxxxxxxx
