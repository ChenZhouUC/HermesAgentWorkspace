+class TestPeopleProfileInjection:
+    """PATCH-14 people-profile: ~/.hermes/people.yaml → system prompt.
+
+    Verifies per-person background/stance injection: matched by id and by
+    name/alias, skipped for unknown authors, and resilient to a missing or
+    malformed data file (must never raise on the prompt path).
+    """
+
+    @staticmethod
+    def _install(tmp_path, monkeypatch, body):
+        from gateway import session as _session
+        path = tmp_path / "people.yaml"
+        path.write_text(body, encoding="utf-8")
+        monkeypatch.setattr(_session, "_people_profiles_path", lambda: path)
+        # Reset the mtime cache so each test reloads from its own temp file.
+        _session._people_profiles_cache.update(mtime=None, by_key={})
+        return path
+
+    @staticmethod
+    def _clear(monkeypatch):
+        from gateway import session as _session
+        monkeypatch.setattr(_session, "_people_profiles_path", lambda: None)
+        _session._people_profiles_cache.update(mtime=None, by_key={})
+
+    def _group_prompt(self, user_id=None, user_name=None):
+        config = GatewayConfig(
+            platforms={Platform.TELEGRAM: PlatformConfig(enabled=True, token="fake")},
+        )
+        source = SessionSource(
+            platform=Platform.TELEGRAM,
+            chat_id="g1",
+            chat_name="Team",
+            chat_type="group",
+            user_id=user_id,
+            user_name=user_name,
+        )
+        return build_session_context_prompt(build_session_context(source, config))
+
+    _SAMPLE = (
+        "people:\n"
+        "  - open_id: ou_abc\n"
+        "    name: 周琛\n"
