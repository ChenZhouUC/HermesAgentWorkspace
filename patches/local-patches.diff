+        truncated = len(reader.pages) > _MAX_PDF_PAGES
+        for index, page in enumerate(reader.pages[:_MAX_PDF_PAGES], start=1):
+            text = (page.extract_text() or "").strip()
+            if text:
+                pages.append(f"# ── Page {index} ──\n{text}")
+        if pages:
+            if truncated:
+                pages.append(f"[PDF truncated after {_MAX_PDF_PAGES} pages]")
+            return "\n\n".join(pages).rstrip("\n") + "\n"
+    except ImportError:
