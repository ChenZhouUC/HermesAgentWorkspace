+    now = 100_000.0
+    # 3 turns × 2 messages; max_messages=3 cannot cut mid-turn → keeps last 2 turns? No:
+    # last 2 turns = 4 rows > 3, so it rounds up to the newest turn only (2 rows).
+    history = _turn("t1", now - 30) + _turn("t2", now - 20) + _turn("t3", now - 10)
+    out = apply_history_retention(history, now=now, max_messages=3)
+    assert [m["content"] for m in out] == ["t3", "ok"]
+
+
+def test_retention_never_splits_tool_call_blocks():
+    now = 100_000.0
+    history = _turn("t1", now - 30) + _tool_turn("t2", now - 10)
+    # max_messages=2 would land inside t2's assistant→tool block; the newest
+    # turn is kept whole instead.
+    out = apply_history_retention(history, now=now, max_messages=2)
+    assert [m.get("content") for m in out][0] == "t2"
+    assert len(out) == 4  # full tool turn intact
+    roles = [m["role"] for m in out]
+    assert roles == ["user", "assistant", "tool", "assistant"]
+
+
+def test_retention_newest_turn_always_kept_even_if_too_old():
+    now = 100_000.0
+    history = _turn("only", now - 999_999)
+    out = apply_history_retention(history, now=now, max_age_seconds=60)
+    assert [m["content"] for m in out] == ["only", "ok"]
+
+
+def test_retention_missing_timestamps_are_treated_as_recent():
+    history = [
+        {"role": "user", "content": "legacy"},
+        {"role": "assistant", "content": "ok"},
+    ] * 3
+    out = apply_history_retention(list(history), now=1e9, max_age_seconds=60)
+    assert len(out) == 6  # nothing dropped: no timestamps → recent
+
+
+def test_retention_age_and_count_combine_to_strictest_cut():
+    now = 100_000.0
+    history = (
+        _turn("t1", now - 90_000)   # too old
+        + _turn("t2", now - 50)     # young
+        + _turn("t3", now - 20)     # young
+        + _turn("t4", now - 10)     # young
+    )
+    # Age would keep t2..t4 (6 rows); count=4 tightens to t3..t4.
+    out = apply_history_retention(history, now=now, max_age_seconds=3_600, max_messages=4)
+    assert [m["content"] for m in out] == ["t3", "ok", "t4", "ok"]
+
+
+def test_retention_no_user_rows_returns_unchanged():
+    history = [{"role": "assistant", "content": "orphan"}]
+    assert apply_history_retention(history, now=1e9, max_messages=1) == history
