+def _render_subordinates(entry: Dict[str, Any]) -> Optional[str]:
+    """Render the subordinate-count line from direct/total report fields."""
+    def _as_int(v):
+        try:
+            return int(v)
+        except (TypeError, ValueError):
+            return 0
+    direct = _as_int(entry.get("direct_reports"))
+    total = _as_int(entry.get("total_reports"))
+    if not (direct or total):
+        return None
+    text = f"直接 {direct} 人"
+    if total and total != direct:
+        text += f"，含各级共 {total} 人"
+    return f"- 下属：{text}"
+
+
+def _render_person_profile(entry: Dict[str, Any]) -> List[str]:
+    """Render a profile block split into public and confidential sections.
+
+    Public fields (name, role, department, address) may be disclosed; everything
+    else is for the agent's own judgement and is wrapped in a confidentiality
+    rule so it is never revealed, confirmed, or hinted at — even under direct
+    questioning.
+    """
+    def _field_line(fld: str, label: str) -> Optional[str]:
+        val = entry.get(fld)
+        if val is None or str(val).strip() == "":
+            return None
+        return f"- {label}：{' '.join(str(val).split())}"  # flatten newlines
+
+    name = entry.get("name") or "this person"
+    lines = [f"**对方画像 / Sender profile — {name}（内部参考·注意保密）:**"]
+
+    public = [ln for fld, label in _PEOPLE_PROFILE_PUBLIC
+              if (ln := _field_line(fld, label))]
+    lines.append(
+        "可对外（被问到可直接说，也可自然用于回复）：姓名、岗位、部门/团队、称呼/address。"
+        "address 若包含多个称呼，通常用 | 分隔，可按语境任选一个称呼对方。"
+    )
+    lines.extend(public)
+
+    private: List[str] = []
+    for fld, label in _PEOPLE_PROFILE_PRIVATE:
+        ln = _field_line(fld, label)
+        if ln:
+            private.append(ln)
+        # Subordinate counts sit right after "manager" (a status signal).
+        if fld == "manager":
+            sub = _render_subordinates(entry)
+            if sub:
+                private.append(sub)
+    notes = _field_line("notes", "备注")
+    if notes:
+        private.append(notes)
+
+    if private:
+        lines.append("仅供你内部判断，严禁透露/确认/暗示（哪怕被直接问或旁敲侧击）：")
+        lines.extend(private)
+        lines.append(_PEOPLE_PROFILE_SECRECY)
+    return lines
+
+
+def _profile_field_values(value: Any) -> List[str]:
+    """Flatten profile field values into non-empty text fragments."""
+    values: List[str] = []
+    if value is None:
+        return values
+    if isinstance(value, str):
+        candidates = [value]
+    elif isinstance(value, (list, tuple, set)):
+        candidates = [str(item) for item in value if item is not None]
+    else:
+        candidates = [str(value)]
+    for item in candidates:
+        flattened = " ".join(str(item).split()).strip()
+        if flattened:
+            values.append(flattened)
+        for part in re.split(r"[|,，;；。.!！?？\n\r]+", str(item)):
+            fragment = " ".join(part.split()).strip()
+            if fragment:
+                values.append(fragment)
+    return values
+
+
+def _redact_text_values(text: str, values: List[str]) -> str:
+    redacted = text
+    for value in sorted(set(values), key=len, reverse=True):
+        if len(value) < 2:
+            continue
+        redacted = re.sub(re.escape(value), "[已隐藏的内部画像信息]", redacted)
+    return redacted
+
+
+# Roster-source literals that must never appear in non-DM output, regardless of
+# whether the current author matched a profile. Guards the mechanism itself
+# (the roster file name), complementing the per-person private-value redaction.
+_PEOPLE_SOURCE_LITERALS = ("people.yaml",)
+
+
+def redact_private_person_profile_text(source: SessionSource, text: str) -> str:
+    """Remove non-public matched-person profile values from outbound chat text.
+
+    The model may use ``people.yaml`` to choose tone and address the current
+    author, but in group chats only name, role, department/team, and address are
+    allowed to appear in the visible reply. This redactor is a final guardrail
+    for exact private-field value leaks, and it also strips roster-source
+    literals (the file name) so the mechanism's existence cannot be named.
+    """
+    if not text:
+        return text
+    for literal in _PEOPLE_SOURCE_LITERALS:
+        text = re.sub(re.escape(literal), "[内部资料]", text, flags=re.IGNORECASE)
+    person = _lookup_person(
+        getattr(source, "user_id", None),
+        getattr(source, "user_id_alt", None),
+        getattr(source, "user_name", None),
+    )
+    if not person:
+        return text
+
+    private_values: List[str] = []
+    for field, _label in _PEOPLE_PROFILE_PRIVATE:
+        private_values.extend(_profile_field_values(person.get(field)))
+    private_values.extend(_profile_field_values(person.get("notes")))
+
+    subordinates = _render_subordinates(person)
+    if subordinates:
+        private_values.extend(_profile_field_values(subordinates))
+
+    return _redact_text_values(text, private_values)
+
+
+# ---------------------------------------------------------------------------
+# Group profiles — local, user-curated per-group persona  [group-profile]
+# ---------------------------------------------------------------------------
+# PATCH-14: Inject per-group language style + capability framing from
+# ~/.hermes/groups.yaml so the agent can present itself differently per audience
+# (tone, and what it tells people it can do) while the sandbox/safety boundary
+# stays identical across groups. Same contract as people profiles: the data file
+# lives in the config repo (OUTSIDE hermes-agent) so it survives upstream
+# updates and stays hand-editable, it hot-reloads by mtime, and the loader never
+# raises — a missing/malformed file yields an empty index so a typo can't break
+# the gateway prompt path. Unlike people profiles, nothing here is confidential.
+
+_group_profiles_cache: Dict[str, Any] = {"mtime": None, "by_key": {}}
+_group_profiles_lock = threading.Lock()
+
+# Per-group persona fields: (yaml key, human label). All presentational.
+_GROUP_PROFILE_FIELDS = (
+    ("style", "语言风格 / 语气"),
+    ("capabilities", "能力栈（可对外介绍自己能做什么）"),
+    ("audience", "群成员画像"),
+    ("intro", "自我介绍口径"),
+    ("service_hours", "服务时间（对外提示）"),
+    ("notes", "备注"),
+)
+
+# Injected for every group/channel session (whether or not a per-group profile
+# matched): when missing tools/permissions degrade a task, the final answer must
+# say so, and deeper conclusions/decisions are deferred to 琛哥 rather than
+# asserted. The sandbox itself is identical across groups — this is about
+# honestly reporting a degraded result, not about apologising for the boundary.
+_GROUP_TOOL_LIMITATION_RULE = (
+    "**能力受限声明规则（群聊）：** 如果本次任务因为某些工具不可用、权限被沙箱"
+    "拦截、缺少凭证或访问失败而**没能完成或效果打折**（例如查不到、没法验证、"
+    "只拿到片面信息），最终产出里必须**明确声明**存在这一限制：说清楚哪一步因为"
+    "什么受限、结论的可信度边界在哪；绝不能把受限当成已验证，也不要假装结果完整。"
+    "凡涉及更深入的结论、判断、决策或对外承诺，宁可保守——给出基于现有信息的"
+    "初步看法即可，并建议**等琛哥确认**后再作准，不替琛哥拍板或担责。"
+)
+
+
+def _group_profiles_path() -> Optional[Path]:
+    """Return the path to ~/.hermes/groups.yaml, or None if home is unresolvable."""
+    try:
+        from hermes_constants import get_hermes_home
+        return get_hermes_home() / "groups.yaml"
+    except Exception:
+        return None
+
+
+def _load_group_profiles() -> Dict[str, Any]:
+    """Load and cache ~/.hermes/groups.yaml, reloading only when its mtime changes.
+
+    Returns a dict whose ``by_key`` maps every chat_id/name/alias (and a
+    casefolded variant) to the owning entry. Absent or malformed files collapse
+    to an empty index instead of raising, mirroring _load_people_profiles.
+    """
+    path = _group_profiles_path()
+    if path is None:
+        return _group_profiles_cache
+    try:
+        mtime = path.stat().st_mtime
+    except OSError:
+        if _group_profiles_cache["mtime"] is not None:
+            with _group_profiles_lock:
+                _group_profiles_cache.update(mtime=None, by_key={})
+        return _group_profiles_cache
+    if _group_profiles_cache["mtime"] == mtime:
+        return _group_profiles_cache
+    with _group_profiles_lock:
+        if _group_profiles_cache["mtime"] == mtime:  # lost the race; already fresh
+            return _group_profiles_cache
+        by_key: Dict[str, Any] = {}
+        try:
+            import yaml
+            with open(path, "r", encoding="utf-8") as fh:
+                data = yaml.safe_load(fh) or {}
+            raw = data.get("groups", []) if isinstance(data, dict) else data
+            if isinstance(raw, list):
+                for ent in raw:
+                    if not isinstance(ent, dict):
+                        continue
+                    keys: List[str] = []
+                    for fld in ("chat_id", "chat_id_alt", "id", "name"):
+                        val = ent.get(fld)
+                        if val:
+                            keys.append(str(val))
+                    aliases = ent.get("aliases") or []
+                    if isinstance(aliases, str):
+                        aliases = [aliases]
+                    keys.extend(str(a) for a in aliases if a)
+                    for key in keys:
+                        by_key.setdefault(key, ent)
+                        by_key.setdefault(key.casefold(), ent)
+        except Exception as exc:  # malformed YAML, unexpected shape, etc.
+            logger.warning("groups.yaml load failed (%s); ignoring group profiles", exc)
+            by_key = {}
+        _group_profiles_cache.update(mtime=mtime, by_key=by_key)
+    return _group_profiles_cache
+
+
+def _lookup_group(*candidates: Optional[str]) -> Optional[Dict[str, Any]]:
+    """Return the first group profile matching any of the given chat ids/names."""
+    by_key = _load_group_profiles()["by_key"]
+    if not by_key:
+        return None
+    for cand in candidates:
+        if not cand:
+            continue
+        hit = by_key.get(str(cand)) or by_key.get(str(cand).casefold())
+        if hit:
+            return hit
+    return None
+
+
+def _render_group_profile(entry: Dict[str, Any]) -> List[str]:
+    """Render the per-group persona block (style + capability framing).
+
+    Purely presentational: it changes how the agent talks and what it says it
+    can do in this group, never the sandbox/safety boundary (identical across
+    groups). Nothing here is confidential.
+    """
+    def _field_line(fld: str, label: str) -> Optional[str]:
+        val = entry.get(fld)
+        if val is None or str(val).strip() == "":
+            return None
+        return f"- {label}：{' '.join(str(val).split())}"  # flatten newlines
+
+    name = entry.get("name") or entry.get("chat_id") or "this group"
+    lines = [f"**本群画像 / Group profile — {name}（按本群定制语气与介绍口径）:**"]
+    for fld, label in _GROUP_PROFILE_FIELDS:
+        ln = _field_line(fld, label)
+        if ln:
+            lines.append(ln)
+    if entry.get("service_hours") is not None and str(entry["service_hours"]).strip():
+        lines.append(
+            "服务时间只是给群成员的提示，不是调度或拒答规则。自我介绍或被问到在线/"
+            "接客时间时，必须自然带上这段信息；普通回答不要机械重复。服务时段之外收到"
+            "消息仍可照常回答，不得仅因为时间而拒答。"
+        )
+    lines.append(
+        "用上面的语言风格与能力栈来应对本群：自我介绍、说明你能做什么、整体语气"
+        "都据此调整。这只改变“怎么表达/介绍”，不改变沙箱与安全边界（各群一致）。"
+    )
+    return lines
+
