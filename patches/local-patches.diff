+# ──────────────────────────────────────────────────────────────────────
+# Replay-history retention window (time + count)  [history-retention]
+# ──────────────────────────────────────────────────────────────────────
+# PATCH-22: long-lived shared group sessions replay their FULL transcript to
+# the model every turn — token-based compression never fires on large-context
+# models, so days-old turns (including one-shot injected instruction blocks
+# and the model's own replies under them) keep steering later turns ("history
+# contamination"). This retention filter bounds what the MODEL sees by
+# wall-clock age and message count. It is a VIEW-level filter: state.db keeps
+# the complete transcript (audit, /resume, search untouched).
+
+
+def _retention_turn_starts(agent_history: List[Dict[str, Any]]) -> List[int]:
+    """Indices of user messages that begin a turn (safe cut points).
+
+    A cut may only land on a plain ``user`` row: cutting between an
+    ``assistant(tool_calls)`` row and its ``tool`` answers (or between a
+    ``tool`` answer and the assistant text that consumes it) breaks the
+    strict adjacency providers enforce and fails the whole request.
+    ``tool_call_id``-bearing user rows never occur, so ``role == "user"``
+    is a sufficient boundary test.
+    """
+    return [
+        i
+        for i, msg in enumerate(agent_history)
+        if isinstance(msg, dict) and msg.get("role") == "user"
+    ]
+
+
+def apply_history_retention(
+    agent_history: List[Dict[str, Any]],
+    *,
+    now: float,
+    max_age_seconds: Optional[float] = None,
+    max_messages: Optional[int] = None,
+) -> List[Dict[str, Any]]:
+    """Bound replayed history by wall-clock age and/or message count.
+
+    Semantics (both limits optional; ``None``/``<=0`` disables that limit):
+
+    - ``max_age_seconds``: drop whole turns whose opening user message is
+      older than the window. Age is read from the user row's ``timestamp``
+      (persisted rows carry one; see ``_build_replay_entry``). A turn whose
+      opening user row has NO timestamp is treated as *recent* — legacy rows
+      and in-memory scaffolding must never be mass-dropped by a config knob.
+    - ``max_messages``: keep at most N trailing messages, rounded UP to the
+      nearest turn boundary so an assistant→tool block is never split. The
+      newest turn is always kept whole even if it alone exceeds N.
+
+    Cuts land only on turn starts (plain user rows). When no user row exists
+    (degenerate/synthetic histories) the list is returned unchanged — there is
+    no safe cut point. Returns the same list object when nothing is dropped.
+    """
+    if not agent_history:
+        return agent_history
+    age_limit: float = float(max_age_seconds or 0)
+    count_limit: int = int(max_messages or 0)
+    age_on = age_limit > 0
+    count_on = count_limit > 0
+    if not (age_on or count_on):
+        return agent_history
+
+    turn_starts = _retention_turn_starts(agent_history)
+    if not turn_starts:
+        return agent_history
+
+    # Candidate cut from the count limit: the earliest turn start that keeps
+    # <= max_messages rows, but never past the newest turn (always kept).
+    cut = 0
+    if count_on:
+        cut = turn_starts[-1]  # fallback: newest turn only
+        for start in turn_starts:
+            if len(agent_history) - start <= count_limit:
+                cut = start
+                break
+
+    # Candidate cut from the age limit: first turn young enough to keep.
+    if age_on:
+        age_cut = turn_starts[-1]  # fallback: newest turn only
+        for start in turn_starts:
+            ts = agent_history[start].get("timestamp")
+            if ts is None or (now - float(ts)) <= age_limit:
+                age_cut = start
+                break
+        cut = max(cut, age_cut)
+
+    if cut <= 0:
+        return agent_history
+    logger.info(
+        "History retention: replaying %d of %d message(s) "
+        "(dropped %d before turn boundary; max_age=%s, max_messages=%s)",
+        len(agent_history) - cut,
+        len(agent_history),
+        cut,
+        max_age_seconds if age_on else "off",
+        max_messages if count_on else "off",
+    )
+    return agent_history[cut:]
