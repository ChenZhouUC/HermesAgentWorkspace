+def _people_profiles_path() -> Optional[Path]:
+    """Return the path to ~/.hermes/people.yaml, or None if home is unresolvable."""
+    try:
+        from hermes_constants import get_hermes_home
+        return get_hermes_home() / "people.yaml"
+    except Exception:
+        return None
+
+
+def _load_people_profiles() -> Dict[str, Any]:
+    """Load and cache ~/.hermes/people.yaml, reloading only when its mtime changes.
+
+    Returns a dict whose ``by_key`` maps every id/name/alias (and a casefolded
+    variant) to the owning entry for O(1) lookup. Absent or malformed files
+    collapse to an empty index instead of raising.
+    """
+    path = _people_profiles_path()
+    if path is None:
+        return _people_profiles_cache
+    try:
+        mtime = path.stat().st_mtime
+    except OSError:
+        # File absent/unreadable: reset the cache once, then keep it empty.
+        if _people_profiles_cache["mtime"] is not None:
+            with _people_profiles_lock:
+                _people_profiles_cache.update(mtime=None, by_key={})
+        return _people_profiles_cache
+    if _people_profiles_cache["mtime"] == mtime:
+        return _people_profiles_cache
+    with _people_profiles_lock:
+        if _people_profiles_cache["mtime"] == mtime:  # lost the race; already fresh
+            return _people_profiles_cache
+        by_key: Dict[str, Any] = {}
+        try:
+            import yaml
+            with open(path, "r", encoding="utf-8") as fh:
+                data = yaml.safe_load(fh) or {}
+            raw = data.get("people", []) if isinstance(data, dict) else data
+            if isinstance(raw, list):
+                for ent in raw:
+                    if not isinstance(ent, dict):
+                        continue
+                    keys: List[str] = []
+                    for fld in ("open_id", "user_id", "union_id", "id", "name"):
+                        val = ent.get(fld)
+                        if val:
+                            keys.append(str(val))
+                    aliases = ent.get("aliases") or []
+                    if isinstance(aliases, str):
+                        aliases = [aliases]
+                    keys.extend(str(a) for a in aliases if a)
+                    for key in keys:
+                        by_key.setdefault(key, ent)
+                        by_key.setdefault(key.casefold(), ent)
+        except Exception as exc:  # malformed YAML, unexpected shape, etc.
+            logger.warning("people.yaml load failed (%s); ignoring profiles", exc)
+            by_key = {}
+        _people_profiles_cache.update(mtime=mtime, by_key=by_key)
+    return _people_profiles_cache
+
+
+def _lookup_person(*candidates: Optional[str]) -> Optional[Dict[str, Any]]:
+    """Return the first profile entry matching any of the given ids/names."""
+    by_key = _load_people_profiles()["by_key"]
+    if not by_key:
+        return None
+    for cand in candidates:
+        if not cand:
+            continue
+        hit = by_key.get(str(cand)) or by_key.get(str(cand).casefold())
+        if hit:
+            return hit
+    return None
+
