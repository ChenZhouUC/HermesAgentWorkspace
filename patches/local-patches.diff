+    async def _fetch_channel_context(
+        self,
+        *,
+        chat_id: str,
+        trigger_message_id: str,
+        trigger_timestamp: Any,
+        chat_type: str,
+    ) -> Optional[FeishuChannelContextSnapshot]:
+        """Fetch recent Feishu group messages as one-turn channel context.
+
+        The gateway prepends ``MessageEvent.channel_context`` to the current
+        turn only. It is not written as durable Hermes conversation history.
+        """
+        if (
+            not getattr(self, "_history_backfill", False)
+            or not getattr(self, "_client", None)
+            or chat_type not in {"group", "forum", "channel"}
+            or not chat_id
+        ):
+            return None
+
+        end_ts = self._coerce_feishu_epoch_seconds(trigger_timestamp)
+        if end_ts is None:
+            end_ts = int(time.time())
+        start_ts = max(0, end_ts - self._history_backfill_seconds)
+
+        try:
+            page_size = max(
+                self._history_backfill_limit + 1,
+                self._assistant_identity_throttle_messages + 1,
+                1,
+            )
+            request = self._build_list_message_request(
+                chat_id=chat_id,
+                start_time=str(start_ts),
+                end_time=str(end_ts),
+                page_size=min(page_size, 50),
+            )
+            response = await asyncio.to_thread(self._client.im.v1.message.list, request)
+            if not response or getattr(response, "success", lambda: False)() is False:
+                code = getattr(response, "code", "unknown")
+                msg = getattr(response, "msg", "message list failed")
+                logger.warning("[Feishu] Failed to fetch channel context for %s: [%s] %s", chat_id, code, msg)
+                return None
+            items = getattr(getattr(response, "data", None), "items", None) or []
+            return self._format_channel_context(
+                items,
+                trigger_message_id=trigger_message_id,
+                trigger_timestamp=end_ts,
+            )
+        except Exception:
+            logger.warning("[Feishu] Failed to fetch channel context for %s", chat_id, exc_info=True)
+            return None
+
+    @staticmethod
+    def _coerce_feishu_epoch_seconds(value: Any) -> Optional[int]:
+        try:
+            parsed = int(value)
+        except (TypeError, ValueError):
+            return None
+        if parsed <= 0:
+            return None
+        # Feishu message create_time values are commonly milliseconds.
+        if parsed > 10_000_000_000:
+            parsed //= 1000
+        return parsed
+
+    def _mark_attachment_backfilled(self, message_id: str) -> None:
+        """Record a message_id whose attachments were stitched onto a turn (LRU-bounded)."""
+        if not message_id:
+            return
+        self._backfilled_attachment_ids[message_id] = None
+        self._backfilled_attachment_ids.move_to_end(message_id)
+        while len(self._backfilled_attachment_ids) > _FEISHU_BACKFILLED_ID_CACHE_SIZE:
+            self._backfilled_attachment_ids.popitem(last=False)
+
+    async def _backfill_sender_attachments(
+        self,
+        *,
+        chat_id: str,
+        trigger_message_id: str,
+        trigger_timestamp: Any,
+        sender_id: Any,
+    ) -> Optional[tuple[List[str], List[str]]]:
+        """Return (media_urls, media_types) for this sender's recent image/file
+        messages within ``_FEISHU_BACKFILL_WINDOW_SECONDS``, or None.
+
+        Stitches a picture/file the sender posted as a separate, un-mentionable
+        message onto a bare @mention follow-up. Bounded, deduped, and silent on
+        failure/timeout so a text-only reply is never blocked.
+        """
+        wanted = {
+            v
+            for v in (
+                getattr(sender_id, "open_id", None),
+                getattr(sender_id, "user_id", None),
+                getattr(sender_id, "union_id", None),
+            )
+            if v
+        }
+        if not wanted or not chat_id or not self._client:
+            return None
+        try:
+            return await asyncio.wait_for(
+                self._collect_sender_attachments(
+                    chat_id=chat_id,
+                    trigger_message_id=trigger_message_id,
+                    trigger_timestamp=trigger_timestamp,
+                    wanted_senders=wanted,
+                ),
+                timeout=_FEISHU_BACKFILL_TIMEOUT_SECONDS,
+            )
+        except Exception:
+            logger.warning("[Feishu] sender-attachment backfill failed for chat=%s", chat_id, exc_info=True)
