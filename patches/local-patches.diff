+# ──────────────────────────────────────────────────────────────────────
+# PATCH-22: gateway replay-history retention config resolution
+# ──────────────────────────────────────────────────────────────────────
+# The retention filter itself (agent.replay_cleanup.apply_history_retention)
+# is covered in tests/agent/test_replay_cleanup.py. These tests cover the
+# gateway side: resolving gateway.history_retention.<platform-key> from
+# config.yaml with the same chat-scope split used by tool/skill config
+# (feishu_group for Feishu groups, feishu for DMs), failing open (no limits)
+# for unconfigured platforms or malformed values.
+#
+# Motivation: long-lived shared group sessions replay their full transcript
+# every turn; token-based compression never fires on large-context models, so
+# days-old injected instruction blocks keep steering later turns ("history
+# contamination", observed 2026-07-14 in the SpaceSight Tech Sharing Group).
+
+import gateway.run as _gateway_run
+from gateway.run import _history_retention_limits_for_source
+from gateway.session import SessionSource
+from gateway.config import Platform
+
+
+def _retention_source(chat_type="group"):
+    return SessionSource(
+        platform=Platform.FEISHU,
+        chat_id="oc_chat",
+        chat_type=chat_type,
+        user_id="ou_user",
+        user_name="member",
+    )
+
+
+_RETENTION_CFG = {
+    "gateway": {
+        "history_retention": {
+            "feishu_group": {"max_age_seconds": 21600, "max_messages": 30},
+        }
+    }
+}
+
+
+def test_retention_feishu_group_limits_resolved(monkeypatch):
+    monkeypatch.setattr(_gateway_run, "_load_gateway_config", lambda: _RETENTION_CFG)
+    max_age, max_msgs = _history_retention_limits_for_source(_retention_source("group"))
+    assert max_age == 21600.0
+    assert max_msgs == 30
+
+
+def test_retention_feishu_dm_not_covered_by_group_key(monkeypatch):
+    # DMs resolve to platform key "feishu", unconfigured here — retention must
+    # stay off so owner DM continuity is untouched.
+    monkeypatch.setattr(_gateway_run, "_load_gateway_config", lambda: _RETENTION_CFG)
+    assert _history_retention_limits_for_source(_retention_source("dm")) == (None, None)
+
+
+def test_retention_unconfigured_platform_fails_open(monkeypatch):
+    monkeypatch.setattr(_gateway_run, "_load_gateway_config", lambda: {})
+    assert _history_retention_limits_for_source(_retention_source("group")) == (None, None)
+
+
+@pytest.mark.parametrize(
+    "entry",
+    [
+        "6h/30",                                     # not a dict
+        {"max_age_seconds": "soon"},                 # unparseable
+        {"max_age_seconds": -1, "max_messages": 0},  # non-positive → off
+        None,
+    ],
+)
+def test_retention_malformed_entries_fail_open(monkeypatch, entry):
+    cfg = {"gateway": {"history_retention": {"feishu_group": entry}}}
+    monkeypatch.setattr(_gateway_run, "_load_gateway_config", lambda: cfg)
+    assert _history_retention_limits_for_source(_retention_source("group")) == (None, None)
+
+
+def test_retention_partial_config_enables_only_that_limit(monkeypatch):
+    cfg = {"gateway": {"history_retention": {"feishu_group": {"max_messages": 30}}}}
+    monkeypatch.setattr(_gateway_run, "_load_gateway_config", lambda: cfg)
+    assert _history_retention_limits_for_source(_retention_source("group")) == (None, 30)
