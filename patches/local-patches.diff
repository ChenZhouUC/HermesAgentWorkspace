+class TestPeopleProfileInjection:
+    """PATCH-14 people-profile: ~/.hermes/people.yaml → system prompt.
+
+    Verifies per-person background/stance injection: matched by id and by
+    name/alias, skipped for unknown authors, and resilient to a missing or
+    malformed data file (must never raise on the prompt path).
+    """
+
+    @staticmethod
+    def _install(tmp_path, monkeypatch, body):
+        from gateway import session as _session
+        path = tmp_path / "people.yaml"
+        path.write_text(body, encoding="utf-8")
+        monkeypatch.setattr(_session, "_people_profiles_path", lambda: path)
+        # Reset the mtime cache so each test reloads from its own temp file.
+        _session._people_profiles_cache.update(mtime=None, by_key={})
+        return path
+
+    @staticmethod
+    def _clear(monkeypatch):
+        from gateway import session as _session
+        monkeypatch.setattr(_session, "_people_profiles_path", lambda: None)
+        _session._people_profiles_cache.update(mtime=None, by_key={})
+
+    def _group_prompt(self, user_id=None, user_name=None):
+        config = GatewayConfig(
+            platforms={Platform.TELEGRAM: PlatformConfig(enabled=True, token="fake")},
+        )
+        source = SessionSource(
+            platform=Platform.TELEGRAM,
+            chat_id="g1",
+            chat_name="Team",
+            chat_type="group",
+            user_id=user_id,
+            user_name=user_name,
+        )
+        return build_session_context_prompt(build_session_context(source, config))
+
+    _SAMPLE = (
+        "people:\n"
+        "  - open_id: ou_abc\n"
+        "    name: 周琛\n"
+        "    aliases: [琛哥]\n"
+        "    role: 老板\n"
+        "    address: 琛哥|老周\n"
+        "    stance: 最高优先级，技术问题要严谨\n"
+        "    risks: 别当成默认用户\n"
+    )
+
+    def test_profile_injected_when_matched_by_id(self, tmp_path, monkeypatch):
+        self._install(tmp_path, monkeypatch, self._SAMPLE)
+        prompt = self._group_prompt(user_id="ou_abc", user_name="周琛")
+        assert "对方画像 / Sender profile — 周琛" in prompt
+        assert "最高优先级" in prompt
+        assert "别当成默认用户" in prompt
+
+    def test_profile_injected_when_matched_by_alias(self, tmp_path, monkeypatch):
+        self._install(tmp_path, monkeypatch, self._SAMPLE)
+        # No id available; fall back to the display name / alias match.
+        prompt = self._group_prompt(user_id=None, user_name="琛哥")
+        assert "对方画像 / Sender profile" in prompt
+        assert "老板" in prompt
+
+    def test_profile_not_injected_for_unknown_author(self, tmp_path, monkeypatch):
+        self._install(tmp_path, monkeypatch, self._SAMPLE)
+        prompt = self._group_prompt(user_id="ou_stranger", user_name="路人")
+        assert "对方画像" not in prompt
+
+    def test_missing_file_is_safe(self, monkeypatch):
+        self._clear(monkeypatch)
+        prompt = self._group_prompt(user_id="ou_abc", user_name="周琛")
+        assert "对方画像" not in prompt
+
+    def test_malformed_yaml_is_safe(self, tmp_path, monkeypatch):
+        # Broken YAML must collapse to an empty index, not raise.
+        self._install(tmp_path, monkeypatch, "people: [ this : is : not valid")
+        prompt = self._group_prompt(user_id="ou_abc", user_name="周琛")
+        assert "对方画像" not in prompt
