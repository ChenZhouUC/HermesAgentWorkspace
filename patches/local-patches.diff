+class TestGroupProfileInjection:
+    """PATCH-14 group-profile: ~/.hermes/groups.yaml → system prompt.
+
+    Verifies per-group persona injection (language style + capability framing):
+    matched by chat_id and by name/alias, skipped for DMs and unknown chats, and
+    resilient to a missing/malformed data file. Service hours are presentational:
+    introductions mention them, but they never restrict replies. The tool-
+    limitation disclosure rule is always present for groups (even with no
+    matched profile) and absent for DMs.
+    """
+
+    @staticmethod
+    def _install(tmp_path, monkeypatch, body):
+        from gateway import session as _session
+        path = tmp_path / "groups.yaml"
+        path.write_text(body, encoding="utf-8")
+        monkeypatch.setattr(_session, "_group_profiles_path", lambda: path)
+        # Reset the mtime cache so each test reloads from its own temp file.
+        _session._group_profiles_cache.update(mtime=None, by_key={})
+        return path
+
+    @staticmethod
+    def _clear(monkeypatch):
+        from gateway import session as _session
+        monkeypatch.setattr(_session, "_group_profiles_path", lambda: None)
+        _session._group_profiles_cache.update(mtime=None, by_key={})
+
+    def _group_prompt(self, chat_id="oc_g1", chat_name="Team", chat_type="group"):
+        config = GatewayConfig(
+            platforms={Platform.TELEGRAM: PlatformConfig(enabled=True, token="fake")},
+        )
+        source = SessionSource(
+            platform=Platform.TELEGRAM,
+            chat_id=chat_id,
+            chat_name=chat_name,
+            chat_type=chat_type,
+            user_id="ou_member",
+            user_name="某成员",
+        )
+        return build_session_context_prompt(build_session_context(source, config))
+
+    def _dm_prompt(self):
+        config = GatewayConfig(
+            platforms={Platform.TELEGRAM: PlatformConfig(enabled=True, token="fake")},
+        )
+        source = SessionSource(
+            platform=Platform.TELEGRAM,
+            chat_id="ou_dm",
+            chat_type="dm",
+            user_id="ou_member",
+            user_name="某成员",
+        )
+        return build_session_context_prompt(build_session_context(source, config))
+
+    _SAMPLE = (
+        "groups:\n"
+        "  - chat_id: oc_g1\n"
+        "    name: SpaceSight 救命稻草\n"
+        "    aliases: [稻草群]\n"
+        "    style: 偏正式、术语精确，面向投资人\n"
+        "    capabilities: 行业调研、文档解读、会议纪要\n"
+        "    intro: 我是琛哥的赛博助手 Gödel，这个群里主要帮忙做调研和文档\n"
+        "    service_hours: 每日 09:00–23:00（北京时间）\n"
+    )
+
+    def test_profile_injected_when_matched_by_chat_id(self, tmp_path, monkeypatch):
+        self._install(tmp_path, monkeypatch, self._SAMPLE)
+        prompt = self._group_prompt(chat_id="oc_g1")
+        assert "本群画像 / Group profile — SpaceSight 救命稻草" in prompt
+        assert "偏正式、术语精确" in prompt
+        assert "行业调研、文档解读、会议纪要" in prompt
+
+    def test_service_hours_are_intro_hint_not_reply_gate(self, tmp_path, monkeypatch):
+        self._install(tmp_path, monkeypatch, self._SAMPLE)
+        prompt = self._group_prompt(chat_id="oc_g1")
+        assert "服务时间（对外提示）：每日 09:00–23:00（北京时间）" in prompt
+        assert "自我介绍或被问到在线/接客时间时，必须自然带上" in prompt
+        assert "不得仅因为时间而拒答" in prompt
+
+    def test_profile_injected_when_matched_by_alias(self, tmp_path, monkeypatch):
+        self._install(tmp_path, monkeypatch, self._SAMPLE)
+        # No chat_id match; fall back to the alias.
+        prompt = self._group_prompt(chat_id="oc_other", chat_name="稻草群")
+        assert "本群画像 / Group profile" in prompt
+        assert "面向投资人" in prompt
+
+    def test_unknown_group_skips_profile_but_keeps_disclosure(self, tmp_path, monkeypatch):
+        self._install(tmp_path, monkeypatch, self._SAMPLE)
+        prompt = self._group_prompt(chat_id="oc_stranger", chat_name="路人群")
+        assert "本群画像" not in prompt
+        # The disclosure rule is universal for groups, profile or not.
+        assert "能力受限声明规则" in prompt
+        assert "等琛哥确认" in prompt
+
+    def test_disclosure_rule_present_for_group(self, tmp_path, monkeypatch):
+        self._install(tmp_path, monkeypatch, self._SAMPLE)
+        prompt = self._group_prompt(chat_id="oc_g1")
+        assert "能力受限声明规则" in prompt
+        assert "明确声明" in prompt
+
+    def test_dm_gets_neither_profile_nor_disclosure(self, tmp_path, monkeypatch):
+        self._install(tmp_path, monkeypatch, self._SAMPLE)
+        prompt = self._dm_prompt()
+        assert "本群画像" not in prompt
+        assert "能力受限声明规则" not in prompt
+
+    def test_people_source_secrecy_rule_present_for_group(self, tmp_path, monkeypatch):
+        # Universal for groups (profile hit or not): never reveal the local
+        # roster mechanism, never offer colleague lookups, and treat any prior
+        # in-history mention of it as a corrected mistake, not a precedent.
+        self._install(tmp_path, monkeypatch, self._SAMPLE)
+        for chat_id, chat_name in (("oc_g1", "Team"), ("oc_stranger", "路人群")):
+            prompt = self._group_prompt(chat_id=chat_id, chat_name=chat_name)
+            assert "人员信息来源保密" in prompt
+            assert "people.yaml" in prompt
+            assert "不要模仿、重复或引用" in prompt
+
+    def test_people_source_secrecy_rule_absent_for_dm(self, tmp_path, monkeypatch):
+        self._install(tmp_path, monkeypatch, self._SAMPLE)
+        prompt = self._dm_prompt()
+        assert "人员信息来源保密" not in prompt
+
+    def test_missing_file_is_safe(self, monkeypatch):
+        self._clear(monkeypatch)
+        prompt = self._group_prompt(chat_id="oc_g1")
+        # No profile, but the loader must not raise and disclosure still applies.
+        assert "本群画像" not in prompt
+        assert "能力受限声明规则" in prompt
+
+    def test_malformed_yaml_is_safe(self, tmp_path, monkeypatch):
+        # Broken YAML must collapse to an empty index, not raise.
+        self._install(tmp_path, monkeypatch, "groups: [ this : is : not valid")
+        prompt = self._group_prompt(chat_id="oc_g1")
+        assert "本群画像" not in prompt
+        assert "能力受限声明规则" in prompt
+
