+# raw markers instead of formatting). Promoted to renderable equivalents by
+# _promote_block_markdown below. ATX headings require a space after the #'s, so
+# mid-line tokens like "issue #5" are never matched.
+_MARKDOWN_ATX_HEADING_RE = re.compile(r"^\s{0,3}#{1,6}\s+(.*?)\s*#*\s*$")
+_MARKDOWN_BLOCKQUOTE_RE = re.compile(r"^(\s*)>\s?(.*)$")
+
+
+def _promote_block_markdown(content: str) -> str:
+    """Rewrite block-level markdown that Feishu post/md drops, outside code.
+
+    Feishu's post ``md`` element renders inline marks (bold, italics, lists,
+    links, inline code) but ignores ATX headings (``#``) and blockquotes
+    (``>``), leaving the raw markers visible. Promote headings to bold and
+    blockquotes to a ``▎`` prefix so they render, while leaving fenced code
+    blocks verbatim (so ``#``/``>`` inside code survive). Tables are left
+    untouched — the caller routes those to plain text separately.
+    """
+    if not content or ("#" not in content and ">" not in content):
+        return content
+
+    out: List[str] = []
+    in_code_block = False
+    for raw_line in content.splitlines():
+        stripped = raw_line.strip()
+        is_fence = bool(
+            _MARKDOWN_FENCE_CLOSE_RE.match(stripped)
+            if in_code_block
+            else _MARKDOWN_FENCE_OPEN_RE.match(stripped)
+        )
+        if is_fence:
+            in_code_block = not in_code_block
+            out.append(raw_line)
+            continue
+        if in_code_block:
+            out.append(raw_line)
+            continue
+        heading = _MARKDOWN_ATX_HEADING_RE.match(raw_line)
+        if heading:
+            title = heading.group(1).strip()
+            out.append(f"**{title}**" if title else "")
+            continue
+        quote = _MARKDOWN_BLOCKQUOTE_RE.match(raw_line)
+        if quote:
+            out.append(f"{quote.group(1)}▎{quote.group(2)}")
+            continue
+        out.append(raw_line)
+    return "\n".join(out)
+
