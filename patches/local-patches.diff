+def _turn(text, ts, reply="ok"):
+    """One complete user→assistant turn; the user row carries the timestamp."""
+    return [
+        {"role": "user", "content": text, "timestamp": ts},
+        {"role": "assistant", "content": reply},
+    ]
+
+
+def _tool_turn(text, ts):
+    """A user turn answered through an assistant(tool_calls)→tool block."""
+    return [
+        {"role": "user", "content": text, "timestamp": ts},
+        _assistant_tc("read_file"),
+        _tool("file contents"),
+        {"role": "assistant", "content": "done"},
+    ]
+
+
+def test_retention_disabled_returns_same_object():
+    history = _turn("hi", 100.0)
+    assert apply_history_retention(history, now=1e9) is history
+    assert apply_history_retention(history, now=1e9, max_age_seconds=0, max_messages=0) is history
+    assert apply_history_retention([], now=1e9, max_messages=2) == []
+
+
+def test_retention_drops_turns_older_than_window():
+    now = 100_000.0
+    history = _turn("old", now - 90_000) + _turn("recent", now - 100)
+    out = apply_history_retention(history, now=now, max_age_seconds=21_600)
+    assert [m["content"] for m in out] == ["recent", "ok"]
+
