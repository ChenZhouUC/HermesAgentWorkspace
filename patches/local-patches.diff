diff --git a/gateway/platforms/feishu.py b/gateway/platforms/feishu.py
index 01b1c3a1..da856fb2 100644
--- a/gateway/platforms/feishu.py
+++ b/gateway/platforms/feishu.py
@@ -1010,6 +1010,90 @@ def _run_official_feishu_ws_client(ws_client: Any, adapter: Any) -> None:
     if original_configure is not None:
         setattr(ws_client, "_configure", _configure_with_overrides)
     _apply_runtime_ws_overrides()
+
+    # Patch _handle_data_frame to support CARD messages.
+    # The upstream lark_oapi WS SDK (<=1.5.3) silently drops MessageType.CARD frames
+    # without dispatching them, so card button callbacks are never fired. We route CARD
+    # frames through the same do_without_validation path used for EVENT frames so that
+    # register_p2_card_action_trigger callbacks (e.g. approval buttons) work in WS mode.
+    _orig_handle_data_frame = ws_client._handle_data_frame  # bound method
+
+    import base64 as _b64
+    import http as _http
+    from lark_oapi.ws.enum import MessageType as _WsMsgType
+    from lark_oapi.ws.const import (
+        HEADER_TYPE as _HDR_TYPE, HEADER_MESSAGE_ID as _HDR_MSG_ID,
+        HEADER_SUM as _HDR_SUM, HEADER_SEQ as _HDR_SEQ,
+        HEADER_TRACE_ID as _HDR_TRACE_ID, HEADER_BIZ_RT as _HDR_BIZ_RT,
+    )
+    from lark_oapi.ws.model import Response as _WsResponse
+    from lark_oapi.core.json import JSON as _WsJSON
+    from lark_oapi.core.const import UTF_8 as _UTF_8
+    from lark_oapi.ws.client import _get_by_key as _ws_get_by_key
+
+    async def _handle_data_frame_with_card_support(frame: Any) -> None:
+        hs = frame.headers
+        try:
+            type_ = _ws_get_by_key(hs, _HDR_TYPE)
+            message_type = _WsMsgType(type_)
+        except Exception:
+            await _orig_handle_data_frame(frame)
+            return
+
+        logger.debug("[Feishu][PATCH-3] frame received type=%s", type_)
+
+        if message_type != _WsMsgType.CARD:
+            await _orig_handle_data_frame(frame)
+            return
+
+        # CARD frame: process through event handler (mirrors EVENT frame handling).
+        # The upstream lark_oapi WS SDK silently drops CARD frames, so approval
+        # button callbacks never fire in WebSocket mode without this patch.
+        msg_id = _ws_get_by_key(hs, _HDR_MSG_ID)
+        trace_id = _ws_get_by_key(hs, _HDR_TRACE_ID)
+        sum_ = _ws_get_by_key(hs, _HDR_SUM)
+        seq = _ws_get_by_key(hs, _HDR_SEQ)
+
+        logger.info("[Feishu][PATCH-3] CARD frame received msg_id=%s trace_id=%s", msg_id, trace_id)
+
+        pl = frame.payload
+        if int(sum_) > 1:
+            pl = ws_client._combine(msg_id, int(sum_), int(seq), pl)
+            if pl is None:
+                logger.warning("[Feishu][PATCH-3] multi-part CARD frame incomplete, skipping")
+                return
+
+        try:
+            pl_preview = pl[:500].decode(_UTF_8, errors="replace") if pl else ""
+            logger.debug("[Feishu][PATCH-3] CARD payload preview: %s", pl_preview)
+        except Exception:
+            pass
+
+        resp = _WsResponse(code=_http.HTTPStatus.OK)
+        try:
+            start = int(round(time.time() * 1000))
+            result = ws_client._event_handler.do_without_validation(pl)
+            end = int(round(time.time() * 1000))
+            logger.info("[Feishu][PATCH-3] CARD callback processed in %dms result=%r", end - start, result)
+            header = hs.add()
+            header.key = _HDR_BIZ_RT
+            header.value = str(end - start)
+            if result is not None:
+                resp.data = _b64.b64encode(_WsJSON.marshal(result).encode(_UTF_8))
+        except Exception as _card_err:
+            logger.error(
+                "[Feishu] Card action callback failed trace_id=%s err=%s",
+                trace_id, _card_err, exc_info=True,
+            )
+            resp = _WsResponse(code=_http.HTTPStatus.INTERNAL_SERVER_ERROR)
+
+        frame.payload = _WsJSON.marshal(resp).encode(_UTF_8)
+        await ws_client._write_message(frame.SerializeToString())
+        logger.info("[Feishu][PATCH-3] CARD response written trace_id=%s code=%s", trace_id, resp.code)
+
+    ws_client._handle_data_frame = _handle_data_frame_with_card_support
+    logger.info("[Feishu][PATCH-3] _handle_data_frame monkey-patched on ws_client id=%s", id(ws_client))
+
     try:
         ws_client.start()
     except Exception:
@@ -1018,6 +1102,7 @@ def _run_official_feishu_ws_client(ws_client: Any, adapter: Any) -> None:
         ws_client_module.websockets.connect = original_connect
         if original_configure is not None:
             setattr(ws_client, "_configure", original_configure)
+        ws_client._handle_data_frame = _orig_handle_data_frame
         pending = [t for t in asyncio.all_tasks(loop) if not t.done()]
         for task in pending:
             task.cancel()
