+        from plugins.platforms.feishu.adapter import FeishuAdapter
+
+        adapter = FeishuAdapter.__new__(FeishuAdapter)
+        adapter._client = Mock()
+        adapter._run_blocking = AsyncMock()
+        return adapter
+
+    def test_extract_tokens_from_current_or_quoted_text_deduplicates_and_caps(self):
+        from plugins.platforms.feishu.adapter import FeishuAdapter
+
+        text = (
+            "https://whales.feishu.cn/file/boxcnFirst "
+            "https://whales.feishu.cn/file/boxcnFirst?from=quote "
+            "https://example.larksuite.com/file/boxcnSecond "
+            "https://whales.feishu.cn/file/boxcnThird "
+            "https://whales.feishu.cn/file/boxcnFourth"
+        )
+        self.assertEqual(
+            FeishuAdapter._extract_drive_file_tokens(text),
+            ["boxcnFirst", "boxcnSecond", "boxcnThird"],
+        )
+
+    def test_drive_download_caches_document_and_preserves_type(self):
+        adapter = self._build_adapter()
+        response = Mock()
+        response.success.return_value = True
+        response.file_name = "report.pdf"
+        response.file = SimpleNamespace(getvalue=lambda: b"%PDF mock body")
+        response.raw = SimpleNamespace(headers={"Content-Type": "application/pdf"})
+        adapter._run_blocking.return_value = response
+
+        with patch(
+            "plugins.platforms.feishu.adapter.cache_document_from_bytes",
+            return_value="/cache/doc_report.pdf",
+        ) as cache:
+            path, media_type = asyncio.run(adapter._download_feishu_drive_file("boxcnToken"))
+
+        self.assertEqual(path, "/cache/doc_report.pdf")
+        self.assertEqual(media_type, "application/pdf")
+        cache.assert_called_once_with(b"%PDF mock body", "report.pdf")
+        request = adapter._run_blocking.call_args.args[1]
+        self.assertEqual(request.file_token, "boxcnToken")
+
+    def test_failed_drive_download_is_non_fatal(self):
+        adapter = self._build_adapter()
+        response = Mock()
+        response.success.return_value = False
+        response.code = 999
+        response.msg = "denied"
+        adapter._run_blocking.return_value = response
+        self.assertEqual(
+            asyncio.run(adapter._download_feishu_drive_file("boxcnDenied")),
+            ("", ""),
+        )
