#!/usr/bin/env bash
set -euo pipefail

LABEL="ai.hermes.logi-watchdog"
INTERVAL_SECONDS=1

usage() {
    cat <<'EOF'
Usage: install_logi_watchdog_launchd [--interval-seconds N]

Installs a LaunchAgent that supervises Logi Options+ (logioptionsplus_agent)
and revives it within a few seconds when it crashes -- typically caused by
display sleep/wake events on external displays (e.g. after an Amphetamine
session ends).

Options:
  --interval-seconds N  Poll cadence in seconds inside the watchdog loop
                        (default: 1, minimum: 1). Lower = faster recovery
                        but slightly higher CPU; 1s gives ~2-3s total
                        recovery time and negligible load.
  -h, --help            Show this help
EOF
}

while [[ $# -gt 0 ]]; do
    case "$1" in
    --interval-seconds)
        [[ $# -ge 2 ]] || {
            echo "Missing value for --interval-seconds" >&2
            exit 2
        }
        INTERVAL_SECONDS="$2"
        shift 2
        ;;
    -h | --help)
        usage
        exit 0
        ;;
    *)
        echo "Unknown argument: $1" >&2
        usage >&2
        exit 2
        ;;
    esac
done

if [[ "$(uname -s)" != "Darwin" ]]; then
    echo "This script only supports macOS launchd." >&2
    exit 1
fi

if ! [[ "$INTERVAL_SECONDS" =~ ^[0-9]+$ ]] || [[ "$INTERVAL_SECONDS" -lt 1 ]]; then
    echo "--interval-seconds must be an integer >= 1" >&2
    exit 2
fi

ROOT="$(CDPATH= cd -- "$(dirname -- "$0")/.." && pwd)"
RUNNER="${ROOT}/scripts/logi_options_watchdog"
PLIST_DIR="${HOME}/Library/LaunchAgents"
PLIST_PATH="${PLIST_DIR}/${LABEL}.plist"
LOG_DIR="${ROOT}/logs"
STDOUT_PATH="${LOG_DIR}/logi-watchdog.stdout.log"
STDERR_PATH="${LOG_DIR}/logi-watchdog.err.log"
PATH_VALUE="${HOME}/.local/bin:/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin"
BOOTSTRAP_DOMAIN="gui/$(id -u)"

if [[ ! -x "$RUNNER" ]]; then
    echo "Watchdog runner is missing or not executable: $RUNNER" >&2
    exit 1
fi

mkdir -p "$PLIST_DIR" "$LOG_DIR"

TMP_PLIST="$(mktemp "${PLIST_PATH}.XXXXXX")"
cleanup() {
    rm -f "$TMP_PLIST"
}
trap cleanup EXIT

cat >"$TMP_PLIST" <<EOF
<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>${LABEL}</string>
    <key>ProgramArguments</key>
    <array>
        <string>${RUNNER}</string>
    </array>
    <key>WorkingDirectory</key>
    <string>${ROOT}</string>
    <key>RunAtLoad</key>
    <true/>
    <key>KeepAlive</key>
    <true/>
    <key>EnvironmentVariables</key>
    <dict>
        <key>HERMES_HOME</key>
        <string>${ROOT}</string>
        <key>PATH</key>
        <string>${PATH_VALUE}</string>
        <key>LOGI_WATCHDOG_INTERVAL_SECONDS</key>
        <string>${INTERVAL_SECONDS}</string>
    </dict>
    <key>StandardOutPath</key>
    <string>${STDOUT_PATH}</string>
    <key>StandardErrorPath</key>
    <string>${STDERR_PATH}</string>
</dict>
</plist>
EOF

plutil -lint "$TMP_PLIST" >/dev/null
mv "$TMP_PLIST" "$PLIST_PATH"
trap - EXIT

launchctl bootout "$BOOTSTRAP_DOMAIN" "$PLIST_PATH" >/dev/null 2>&1 || true
launchctl bootstrap "$BOOTSTRAP_DOMAIN" "$PLIST_PATH"

printf 'Installed LaunchAgent:\n'
printf '  %s\n' "$PLIST_PATH"
printf '\n'
printf 'Label:          %s\n' "$LABEL"
printf 'Poll interval:  %ss\n' "$INTERVAL_SECONDS"
printf 'Watchdog log:   %s\n' "${LOG_DIR}/logi-watchdog.log"
printf 'Stdout:         %s\n' "$STDOUT_PATH"
printf 'Stderr:         %s\n' "$STDERR_PATH"
printf '\n'
printf 'To inspect:\n'
printf '  launchctl print %s/%s\n' "$BOOTSTRAP_DOMAIN" "$LABEL"
printf '  tail -f %s\n' "${LOG_DIR}/logi-watchdog.log"
printf '\n'
printf 'To uninstall:\n'
printf '  launchctl bootout %s %s\n' "$BOOTSTRAP_DOMAIN" "$PLIST_PATH"
printf '  rm -f %s\n' "$PLIST_PATH"
