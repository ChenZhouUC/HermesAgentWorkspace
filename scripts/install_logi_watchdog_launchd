#!/usr/bin/env bash
set -euo pipefail

POLL_LABEL="ai.hermes.logi-watchdog"
REACTOR_LABEL="ai.hermes.logi-display-reactor"
INTERVAL_SECONDS=1
DEBOUNCE_SECONDS=30

usage() {
    cat <<'EOF'
Usage: install_logi_watchdog_launchd [--interval-seconds N] [--debounce-seconds N]

Installs two complementary LaunchAgents for Logi Options+ stability:

  1. ai.hermes.logi-watchdog
       Bash polling watchdog. Every N seconds checks whether
       logioptionsplus_agent is alive; restarts it via launchctl kickstart
       (with open -a fallback) if missing. Catches "really dead" cases when
       Logi's own KeepAlive misses due to throttling or clean-exit paths.

  2. ai.hermes.logi-display-reactor
       Swift display-reconfiguration reactor. Subscribes to
       CGDisplayRegisterReconfigurationCallback; when the external display
       link renegotiates (e.g. after an Amphetamine session ends), SIGKILLs
       logioptionsplus_agent so the polling watchdog and Logi's own
       KeepAlive bring up a fresh, healthy process. Catches "alive but
       broken" cases when the agent process is still around but its state
       is corrupted by the display event.

Both LaunchAgents share /Users/<you>/.hermes/logs/logi-watchdog.log.

Options:
  --interval-seconds N  Poll cadence inside the bash watchdog
                        (default: 1, minimum: 1).
  --debounce-seconds N  Minimum gap between reactor SIGKILLs after rapid
                        wake events (default: 30, minimum: 1). Coalesces
                        the screenIsUnlocked + didWake notification pair
                        that fires for a single physical wake cycle.
  -h, --help            Show this help
EOF
}

while [[ $# -gt 0 ]]; do
    case "$1" in
    --interval-seconds)
        [[ $# -ge 2 ]] || {
            echo "Missing value for --interval-seconds" >&2
            exit 2
        }
        INTERVAL_SECONDS="$2"
        shift 2
        ;;
    --debounce-seconds)
        [[ $# -ge 2 ]] || {
            echo "Missing value for --debounce-seconds" >&2
            exit 2
        }
        DEBOUNCE_SECONDS="$2"
        shift 2
        ;;
    -h | --help)
        usage
        exit 0
        ;;
    *)
        echo "Unknown argument: $1" >&2
        usage >&2
        exit 2
        ;;
    esac
done

if [[ "$(uname -s)" != "Darwin" ]]; then
    echo "This script only supports macOS launchd." >&2
    exit 1
fi

if ! [[ "$INTERVAL_SECONDS" =~ ^[0-9]+$ ]] || [[ "$INTERVAL_SECONDS" -lt 1 ]]; then
    echo "--interval-seconds must be an integer >= 1" >&2
    exit 2
fi

if ! [[ "$DEBOUNCE_SECONDS" =~ ^[0-9]+$ ]] || [[ "$DEBOUNCE_SECONDS" -lt 1 ]]; then
    echo "--debounce-seconds must be an integer >= 1" >&2
    exit 2
fi

ROOT="$(CDPATH= cd -- "$(dirname -- "$0")/.." && pwd)"
POLL_RUNNER="${ROOT}/scripts/logi_options_watchdog"
REACTOR_RUNNER="${ROOT}/scripts/logi_display_reactor.swift"
PLIST_DIR="${HOME}/Library/LaunchAgents"
POLL_PLIST_PATH="${PLIST_DIR}/${POLL_LABEL}.plist"
REACTOR_PLIST_PATH="${PLIST_DIR}/${REACTOR_LABEL}.plist"
LOG_DIR="${ROOT}/logs"
POLL_STDOUT_PATH="${LOG_DIR}/logi-watchdog.stdout.log"
POLL_STDERR_PATH="${LOG_DIR}/logi-watchdog.err.log"
REACTOR_STDOUT_PATH="${LOG_DIR}/logi-display-reactor.stdout.log"
REACTOR_STDERR_PATH="${LOG_DIR}/logi-display-reactor.err.log"
PATH_VALUE="${HOME}/.local/bin:/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin"
BOOTSTRAP_DOMAIN="gui/$(id -u)"

if [[ ! -x "$POLL_RUNNER" ]]; then
    echo "Polling watchdog runner is missing or not executable: $POLL_RUNNER" >&2
    exit 1
fi
if [[ ! -x "$REACTOR_RUNNER" ]]; then
    echo "Display reactor runner is missing or not executable: $REACTOR_RUNNER" >&2
    exit 1
fi

mkdir -p "$PLIST_DIR" "$LOG_DIR"

TMP_POLL_PLIST="$(mktemp "${POLL_PLIST_PATH}.XXXXXX")"
TMP_REACTOR_PLIST="$(mktemp "${REACTOR_PLIST_PATH}.XXXXXX")"
cleanup() {
    rm -f "$TMP_POLL_PLIST" "$TMP_REACTOR_PLIST"
}
trap cleanup EXIT

cat >"$TMP_POLL_PLIST" <<EOF
<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>${POLL_LABEL}</string>
    <key>ProgramArguments</key>
    <array>
        <string>${POLL_RUNNER}</string>
    </array>
    <key>WorkingDirectory</key>
    <string>${ROOT}</string>
    <key>RunAtLoad</key>
    <true/>
    <key>KeepAlive</key>
    <true/>
    <key>EnvironmentVariables</key>
    <dict>
        <key>HERMES_HOME</key>
        <string>${ROOT}</string>
        <key>PATH</key>
        <string>${PATH_VALUE}</string>
        <key>LOGI_WATCHDOG_INTERVAL_SECONDS</key>
        <string>${INTERVAL_SECONDS}</string>
    </dict>
    <key>StandardOutPath</key>
    <string>${POLL_STDOUT_PATH}</string>
    <key>StandardErrorPath</key>
    <string>${POLL_STDERR_PATH}</string>
</dict>
</plist>
EOF

cat >"$TMP_REACTOR_PLIST" <<EOF
<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>${REACTOR_LABEL}</string>
    <key>ProgramArguments</key>
    <array>
        <string>${REACTOR_RUNNER}</string>
    </array>
    <key>WorkingDirectory</key>
    <string>${ROOT}</string>
    <key>RunAtLoad</key>
    <true/>
    <key>KeepAlive</key>
    <true/>
    <key>EnvironmentVariables</key>
    <dict>
        <key>HERMES_HOME</key>
        <string>${ROOT}</string>
        <key>PATH</key>
        <string>${PATH_VALUE}</string>
        <key>LOGI_DISPLAY_DEBOUNCE_SECONDS</key>
        <string>${DEBOUNCE_SECONDS}</string>
    </dict>
    <key>StandardOutPath</key>
    <string>${REACTOR_STDOUT_PATH}</string>
    <key>StandardErrorPath</key>
    <string>${REACTOR_STDERR_PATH}</string>
</dict>
</plist>
EOF

plutil -lint "$TMP_POLL_PLIST" >/dev/null
plutil -lint "$TMP_REACTOR_PLIST" >/dev/null
mv "$TMP_POLL_PLIST" "$POLL_PLIST_PATH"
mv "$TMP_REACTOR_PLIST" "$REACTOR_PLIST_PATH"
trap - EXIT

launchctl bootout "$BOOTSTRAP_DOMAIN" "$POLL_PLIST_PATH" >/dev/null 2>&1 || true
launchctl bootout "$BOOTSTRAP_DOMAIN" "$REACTOR_PLIST_PATH" >/dev/null 2>&1 || true
launchctl bootstrap "$BOOTSTRAP_DOMAIN" "$POLL_PLIST_PATH"
launchctl bootstrap "$BOOTSTRAP_DOMAIN" "$REACTOR_PLIST_PATH"

printf 'Installed LaunchAgents:\n'
printf '  %s\n' "$POLL_PLIST_PATH"
printf '  %s\n' "$REACTOR_PLIST_PATH"
printf '\n'
printf 'Polling watchdog (catches "really dead"):\n'
printf '  Label:          %s\n' "$POLL_LABEL"
printf '  Poll interval:  %ss\n' "$INTERVAL_SECONDS"
printf '  Stdout:         %s\n' "$POLL_STDOUT_PATH"
printf '  Stderr:         %s\n' "$POLL_STDERR_PATH"
printf '\n'
printf 'Display reactor (catches "alive but broken"):\n'
printf '  Label:          %s\n' "$REACTOR_LABEL"
printf '  Debounce:       %ss\n' "$DEBOUNCE_SECONDS"
printf '  Stdout:         %s\n' "$REACTOR_STDOUT_PATH"
printf '  Stderr:         %s\n' "$REACTOR_STDERR_PATH"
printf '\n'
printf 'Shared business log: %s\n' "${LOG_DIR}/logi-watchdog.log"
printf '\n'
printf 'To inspect:\n'
printf '  launchctl print %s/%s\n' "$BOOTSTRAP_DOMAIN" "$POLL_LABEL"
printf '  launchctl print %s/%s\n' "$BOOTSTRAP_DOMAIN" "$REACTOR_LABEL"
printf '  tail -f %s\n' "${LOG_DIR}/logi-watchdog.log"
printf '\n'
printf 'To uninstall both:\n'
printf '  launchctl bootout %s %s\n' "$BOOTSTRAP_DOMAIN" "$POLL_PLIST_PATH"
printf '  launchctl bootout %s %s\n' "$BOOTSTRAP_DOMAIN" "$REACTOR_PLIST_PATH"
printf '  rm -f %s %s\n' "$POLL_PLIST_PATH" "$REACTOR_PLIST_PATH"
