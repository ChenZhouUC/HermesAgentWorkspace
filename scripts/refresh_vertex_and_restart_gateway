#!/bin/sh
set -eu

ROOT="$(CDPATH= cd -- "$(dirname -- "$0")/.." && pwd)"
PATH="$HOME/.local/bin:/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin:${PATH:-}"
export PATH
export HERMES_HOME="${HERMES_HOME:-$ROOT}"
ENV_FILE="${HERMES_HOME}/.env"
LOCK_ROOT="${HERMES_HOME}/.locks"
LOCK_DIR="${LOCK_ROOT}/vertex-refresh.lock"

timestamp() {
    date '+%Y-%m-%d %H:%M:%S %z'
}

log() {
    printf '[%s] %s\n' "$(timestamp)" "$*"
}

release_lock() {
    rm -f "${LOCK_DIR}/pid" 2>/dev/null || true
    rmdir "$LOCK_DIR" 2>/dev/null || true
}

on_signal_stop() {
    # Clean, SUCCESSFUL stop when preempted by a manual run (or any signal).
    # The watcher relies on this so a manual preemption is recorded as exit 0,
    # not a failure.
    log "Refresh run stopped (preempted by a manual run or signal); exiting cleanly"
    release_lock
    trap - EXIT
    exit 0
}

set_lock_traps() {
    trap release_lock EXIT
    trap on_signal_stop INT TERM HUP
}

acquire_lock() {
    force="${1:-false}"
    mkdir -p "$LOCK_ROOT"
    if mkdir "$LOCK_DIR" 2>/dev/null; then
        printf '%s\n' "$$" >"${LOCK_DIR}/pid"
        set_lock_traps
        return 0
    fi

    holder=""
    if [ -f "${LOCK_DIR}/pid" ]; then
        holder="$(cat "${LOCK_DIR}/pid" 2>/dev/null || true)"
    fi
    if [ -n "$holder" ] && kill -0 "$holder" 2>/dev/null; then
        if [ "$force" != true ]; then
            log "Another Vertex refresh is already running (pid $holder); skipping"
            exit 0
        fi
        # Manual/urgent run must never be blocked. Stop the in-progress
        # (usually idle-waiting) watcher refresh first, mark it stopped, then
        # take over.
        log "Manual run preempting in-progress watcher refresh (pid $holder)"
        kill -TERM "$holder" 2>/dev/null || true
        _i=0
        while [ "$_i" -lt 5 ] && kill -0 "$holder" 2>/dev/null; do
            sleep 1
            _i=$((_i + 1))
        done
        if kill -0 "$holder" 2>/dev/null; then
            kill -KILL "$holder" 2>/dev/null || true
            log "Watcher refresh (pid $holder) did not stop in time; force-killed"
        else
            log "Watcher refresh (pid $holder) stopped successfully"
        fi
    fi

    rm -f "${LOCK_DIR}/pid" 2>/dev/null || true
    rmdir "$LOCK_DIR" 2>/dev/null || true
    if mkdir "$LOCK_DIR" 2>/dev/null; then
        printf '%s\n' "$$" >"${LOCK_DIR}/pid"
        set_lock_traps
        return 0
    fi

    if [ "$force" = true ]; then
        log "Proceeding without exclusive lock (manual force)"
        set_lock_traps
        return 0
    fi
    log "Another Vertex refresh is already running; skipping"
    exit 0
}

read_env_value() {
    key="$1"
    if [ ! -f "$ENV_FILE" ]; then
        return 1
    fi
    value=$(grep -E "^${key}=" "$ENV_FILE" | tail -n 1 | sed "s/^${key}=//") || return 1
    [ -n "$value" ] || return 1
    printf '%s\n' "$value"
}

HERMES_GOOGLE_APPLICATION_CREDENTIALS="$(read_env_value GOOGLE_APPLICATION_CREDENTIALS || true)"
if [ -n "$HERMES_GOOGLE_APPLICATION_CREDENTIALS" ]; then
    GOOGLE_APPLICATION_CREDENTIALS="$HERMES_GOOGLE_APPLICATION_CREDENTIALS"
    export GOOGLE_APPLICATION_CREDENTIALS
elif [ -n "${GOOGLE_APPLICATION_CREDENTIALS:-}" ]; then
    export GOOGLE_APPLICATION_CREDENTIALS
fi

# --- Parse our own flags; forward everything else to the token-refresh helper.
WAIT_IDLE=false
_kept=""
for _arg in "$@"; do
    case "$_arg" in
    --wait-idle | --graceful)
        WAIT_IDLE=true
        ;;
    -h | --help)
        printf 'Usage: %s [--wait-idle] [refresh-args...]\n' "$(basename "$0")"
        printf '  (default)    refresh token, then restart gateway IMMEDIATELY (no wait for active agents)\n'
        printf '  --wait-idle  drain active agents, then request a graceful planned restart (watcher use)\n'
        exit 0
        ;;
    *)
        _kept="${_kept:+$_kept }$_arg"
        ;;
    esac
done
# shellcheck disable=SC2086
set -- $_kept

# Manual/urgent runs (default) preempt any in-progress watcher refresh; the
# graceful watcher path (--wait-idle) waits its turn instead.
if [ "$WAIT_IDLE" = true ]; then
    acquire_lock
else
    acquire_lock true
fi

VERTEX_LOCATION_VALUE="$(read_env_value VERTEX_LOCATION || true)"
if [ -z "$VERTEX_LOCATION_VALUE" ]; then
    VERTEX_LOCATION_VALUE="${VERTEX_LOCATION:-}"
fi

refresh_args="$*"
set -- --env-file "$ENV_FILE"
if [ -n "${GOOGLE_APPLICATION_CREDENTIALS:-}" ]; then
    set -- "$@" --credentials "$GOOGLE_APPLICATION_CREDENTIALS"
fi
if [ -n "$VERTEX_LOCATION_VALUE" ]; then
    set -- "$@" --location "$VERTEX_LOCATION_VALUE"
fi
if [ -n "$refresh_args" ]; then
    # shellcheck disable=SC2086
    set -- "$@" $refresh_args
fi

MAX_RETRIES=3
RETRY_INTERVAL=60
RESTART_IDLE_WAIT_SECONDS="${HERMES_VERTEX_RESTART_IDLE_WAIT_SECONDS:-600}"
RESTART_IDLE_POLL_SECONDS="${HERMES_VERTEX_RESTART_IDLE_POLL_SECONDS:-5}"

is_uint() {
    case "$1" in
    '' | *[!0-9]*)
        return 1
        ;;
    *)
        return 0
        ;;
    esac
}

if ! is_uint "$RESTART_IDLE_WAIT_SECONDS"; then
    RESTART_IDLE_WAIT_SECONDS=600
fi
if ! is_uint "$RESTART_IDLE_POLL_SECONDS" || [ "$RESTART_IDLE_POLL_SECONDS" -eq 0 ]; then
    RESTART_IDLE_POLL_SECONDS=5
fi

python_bin() {
    if [ -x "$ROOT/hermes-agent/venv/bin/python" ]; then
        printf '%s\n' "$ROOT/hermes-agent/venv/bin/python"
    elif command -v python3 >/dev/null 2>&1; then
        command -v python3
    else
        command -v python
    fi
}

gateway_service_target() {
    printf 'gui/%s/ai.hermes.gateway\n' "$(id -u)"
}

gateway_service_installed() {
    launchctl print "$(gateway_service_target)" >/dev/null 2>&1
}

gateway_pid() {
    launchctl print "$(gateway_service_target)" 2>/dev/null |
        awk '/^[[:space:]]*pid = [0-9]+/ { print $3; exit }'
}

gateway_active_agents() {
    state_file="${HERMES_HOME}/gateway_state.json"
    if [ ! -f "$state_file" ]; then
        printf '0\n'
        return 0
    fi
    py="$(python_bin)"
    "$py" - "$state_file" <<'PY'
import json
import sys

try:
    with open(sys.argv[1], encoding="utf-8") as f:
        state = json.load(f)
    print(int(state.get("active_agents") or 0))
except Exception:
    print(0)
PY
}

wait_for_gateway_idle() {
    max_wait="$1"
    poll="$2"
    active="$(gateway_active_agents)"
    if [ "$active" -le 0 ]; then
        return 0
    fi

    log "Gateway has ${active} active agent(s); waiting up to ${max_wait}s before restart"
    waited=0
    while [ "$waited" -lt "$max_wait" ]; do
        sleep "$poll"
        waited=$((waited + poll))
        active="$(gateway_active_agents)"
        if [ "$active" -le 0 ]; then
            log "Gateway is idle; continuing planned restart"
            return 0
        fi
    done

    log "Gateway still has ${active} active agent(s) after ${max_wait}s; requesting planned restart anyway"
    return 1
}

request_planned_gateway_restart() {
    pid="$(gateway_pid)"
    if [ -z "$pid" ]; then
        log "Gateway PID not found; cannot request planned restart"
        return 1
    fi

    log "Requesting Hermes gateway planned restart via SIGUSR1 (pid ${pid})"
    if kill -USR1 "$pid" 2>/dev/null; then
        log "Hermes gateway planned restart requested"
        return 0
    fi

    log "Failed to signal gateway PID ${pid}"
    return 1
}

gateway_running() {
    pid="$(gateway_pid)"
    [ -n "$pid" ] && kill -0 "$pid" 2>/dev/null
}

force_restart_now() {
    # Manual/urgent immediate restart: never wait for active agents, and keep
    # escalating until the gateway is confirmed back up. In-flight agent runs
    # are intentionally interrupted.
    target="$(gateway_service_target)"
    log "Immediate gateway restart (not waiting for active agents)"

    pid="$(gateway_pid)"
    if [ -n "$pid" ]; then
        kill -KILL "$pid" 2>/dev/null || true
        log "Sent SIGKILL to gateway pid ${pid}"
    fi

    # launchd KeepAlive auto-restarts on exit; kickstart makes it deterministic.
    launchctl kickstart "$target" 2>/dev/null || true

    waited=0
    while [ "$waited" -lt 30 ]; do
        if gateway_running; then
            log "Gateway is back up (pid $(gateway_pid))"
            return 0
        fi
        sleep 1
        waited=$((waited + 1))
        if [ "$((waited % 5))" -eq 0 ]; then
            launchctl kickstart -k "$target" 2>/dev/null ||
                hermes gateway start 2>/dev/null || true
        fi
    done

    log "WARNING: gateway not confirmed up after 30s; last-resort restart"
    launchctl kickstart -k "$target" 2>/dev/null || true
    hermes gateway start 2>/dev/null || true
    if gateway_running; then
        log "Gateway up after last-resort restart"
    else
        log "ERROR: gateway still not confirmed up"
    fi
    return 0
}

_refresh_ok=false
for _attempt in $(seq 1 "$MAX_RETRIES"); do
    log "Refreshing Vertex access token (attempt ${_attempt}/${MAX_RETRIES})"
    if "$ROOT/scripts/refresh_vertex_access_token" "$@" 2>&1; then
        _refresh_ok=true
        break
    fi
    if [ "$_attempt" -lt "$MAX_RETRIES" ]; then
        log "Token refresh failed; retrying in ${RETRY_INTERVAL}s"
        sleep "$RETRY_INTERVAL"
    fi
done

if ! $_refresh_ok; then
    log "ERROR: Vertex token refresh failed after ${MAX_RETRIES} attempts"
    osascript -e 'display notification "Token 刷新连续 '"$MAX_RETRIES"' 次失败，Gemini 将不可用。请检查网络后手动执行 refresh。" with title "Hermes Vertex" subtitle "Token 刷新失败"' 2>/dev/null || true
    release_lock
    exit 1
fi

if gateway_service_installed; then
    if [ "$WAIT_IDLE" = true ]; then
        # Graceful path (hermes-managed watcher): let active agents finish, then
        # request a planned drain-restart; fall back to a harder restart.
        wait_for_gateway_idle "$RESTART_IDLE_WAIT_SECONDS" "$RESTART_IDLE_POLL_SECONDS" || true
        if request_planned_gateway_restart; then
            :
        else
            log "Planned gateway restart failed, falling back to hermes gateway restart"
            if hermes gateway restart; then
                log "Hermes gateway restarted"
            else
                log "Gateway restart failed, trying start"
                hermes gateway start
                log "Hermes gateway started"
            fi
        fi
    else
        # Default path (manual/urgent): restart NOW, never wait for active agents.
        force_restart_now
    fi
else
    log "Gateway launchd service not installed; attempting best-effort start"
    hermes gateway restart 2>/dev/null || hermes gateway start 2>/dev/null ||
        log "WARNING: could not (re)start gateway — launchd service not installed"
fi
