#!/usr/bin/env bash
set -euo pipefail

INTERVAL_LABEL="ai.hermes.vertex-refresh"
WAKE_LABEL="ai.hermes.vertex-wake"
INTERVAL_SECONDS=3000
RUN_NOW=true

usage() {
    cat <<'EOF'
Usage: install_vertex_refresh_launchd [--interval-seconds N] [--no-run-now]

Installs two dedicated LaunchAgents:
  1. A periodic refresh agent that refreshes the Vertex access token and
     restarts the Hermes gateway.
  2. A wake watcher that triggers the same refresh flow once when macOS
     resumes from sleep.

Options:
  --interval-seconds N  Refresh cadence in seconds (default: 3000, i.e. 50 min)
  --no-run-now          Install and load the periodic LaunchAgent without running it immediately
  -h, --help            Show this help
EOF
}

while [[ $# -gt 0 ]]; do
    case "$1" in
    --interval-seconds)
        [[ $# -ge 2 ]] || {
            echo "Missing value for --interval-seconds" >&2
            exit 2
        }
        INTERVAL_SECONDS="$2"
        shift 2
        ;;
    --no-run-now)
        RUN_NOW=false
        shift
        ;;
    -h | --help)
        usage
        exit 0
        ;;
    *)
        echo "Unknown argument: $1" >&2
        usage >&2
        exit 2
        ;;
    esac
done

if [[ "$(uname -s)" != "Darwin" ]]; then
    echo "This script only supports macOS launchd." >&2
    exit 1
fi

if ! [[ "$INTERVAL_SECONDS" =~ ^[0-9]+$ ]] || [[ "$INTERVAL_SECONDS" -lt 60 ]]; then
    echo "--interval-seconds must be an integer >= 60" >&2
    exit 2
fi

ROOT="$(CDPATH= cd -- "$(dirname -- "$0")/.." && pwd)"
INTERVAL_RUNNER="${ROOT}/scripts/refresh_vertex_and_restart_gateway"
WAKE_RUNNER="${ROOT}/scripts/vertex_wake_watcher.swift"
PLIST_DIR="${HOME}/Library/LaunchAgents"
INTERVAL_PLIST_PATH="${PLIST_DIR}/${INTERVAL_LABEL}.plist"
WAKE_PLIST_PATH="${PLIST_DIR}/${WAKE_LABEL}.plist"
LOG_DIR="${ROOT}/logs"
INTERVAL_STDOUT_PATH="${LOG_DIR}/vertex-refresh.log"
INTERVAL_STDERR_PATH="${LOG_DIR}/vertex-refresh.err.log"
WAKE_STDOUT_PATH="${LOG_DIR}/vertex-wake.log"
WAKE_STDERR_PATH="${LOG_DIR}/vertex-wake.err.log"
PATH_VALUE="${HOME}/.local/bin:/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin"
BOOTSTRAP_DOMAIN="gui/$(id -u)"
INTERVAL_RUN_AT_LOAD_TAG="true"

if [[ "$RUN_NOW" != true ]]; then
    INTERVAL_RUN_AT_LOAD_TAG="false"
fi

if [[ ! -x "$INTERVAL_RUNNER" ]]; then
    echo "Interval runner is missing or not executable: $INTERVAL_RUNNER" >&2
    exit 1
fi
if [[ ! -x "$WAKE_RUNNER" ]]; then
    echo "Wake runner is missing or not executable: $WAKE_RUNNER" >&2
    exit 1
fi

mkdir -p "$PLIST_DIR" "$LOG_DIR"

TMP_INTERVAL_PLIST="$(mktemp "${INTERVAL_PLIST_PATH}.XXXXXX")"
TMP_WAKE_PLIST="$(mktemp "${WAKE_PLIST_PATH}.XXXXXX")"
cleanup() {
    rm -f "$TMP_INTERVAL_PLIST" "$TMP_WAKE_PLIST"
}
trap cleanup EXIT

cat >"$TMP_INTERVAL_PLIST" <<EOF
<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>${INTERVAL_LABEL}</string>
    <key>ProgramArguments</key>
    <array>
        <string>${INTERVAL_RUNNER}</string>
    </array>
    <key>WorkingDirectory</key>
    <string>${ROOT}</string>
    <key>RunAtLoad</key>
    <${INTERVAL_RUN_AT_LOAD_TAG}/>
    <key>StartInterval</key>
    <integer>${INTERVAL_SECONDS}</integer>
    <key>EnvironmentVariables</key>
    <dict>
        <key>HERMES_HOME</key>
        <string>${ROOT}</string>
        <key>PATH</key>
        <string>${PATH_VALUE}</string>
    </dict>
    <key>StandardOutPath</key>
    <string>${INTERVAL_STDOUT_PATH}</string>
    <key>StandardErrorPath</key>
    <string>${INTERVAL_STDERR_PATH}</string>
</dict>
</plist>
EOF

cat >"$TMP_WAKE_PLIST" <<EOF
<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>${WAKE_LABEL}</string>
    <key>ProgramArguments</key>
    <array>
        <string>${WAKE_RUNNER}</string>
    </array>
    <key>WorkingDirectory</key>
    <string>${ROOT}</string>
    <key>RunAtLoad</key>
    <true/>
    <key>KeepAlive</key>
    <true/>
    <key>EnvironmentVariables</key>
    <dict>
        <key>HERMES_HOME</key>
        <string>${ROOT}</string>
        <key>PATH</key>
        <string>${PATH_VALUE}</string>
    </dict>
    <key>StandardOutPath</key>
    <string>${WAKE_STDOUT_PATH}</string>
    <key>StandardErrorPath</key>
    <string>${WAKE_STDERR_PATH}</string>
</dict>
</plist>
EOF

plutil -lint "$TMP_INTERVAL_PLIST" >/dev/null
plutil -lint "$TMP_WAKE_PLIST" >/dev/null
mv "$TMP_INTERVAL_PLIST" "$INTERVAL_PLIST_PATH"
mv "$TMP_WAKE_PLIST" "$WAKE_PLIST_PATH"
trap - EXIT

launchctl bootout "$BOOTSTRAP_DOMAIN" "$INTERVAL_PLIST_PATH" >/dev/null 2>&1 || true
launchctl bootout "$BOOTSTRAP_DOMAIN" "$WAKE_PLIST_PATH" >/dev/null 2>&1 || true
launchctl bootstrap "$BOOTSTRAP_DOMAIN" "$INTERVAL_PLIST_PATH"
launchctl bootstrap "$BOOTSTRAP_DOMAIN" "$WAKE_PLIST_PATH"

printf 'Installed LaunchAgents:\n'
printf '  %s\n' "$INTERVAL_PLIST_PATH"
printf '  %s\n' "$WAKE_PLIST_PATH"
printf '\n'
printf 'Periodic refresh:\n'
printf '  Label: %s\n' "$INTERVAL_LABEL"
printf '  Interval: %ss\n' "$INTERVAL_SECONDS"
printf '  Stdout: %s\n' "$INTERVAL_STDOUT_PATH"
printf '  Stderr: %s\n' "$INTERVAL_STDERR_PATH"
printf '\n'
printf 'Wake watcher:\n'
printf '  Label: %s\n' "$WAKE_LABEL"
printf '  Stdout: %s\n' "$WAKE_STDOUT_PATH"
printf '  Stderr: %s\n' "$WAKE_STDERR_PATH"
printf '\n'
printf 'To inspect:\n'
printf '  launchctl print %s/%s\n' "$BOOTSTRAP_DOMAIN" "$INTERVAL_LABEL"
printf '  launchctl print %s/%s\n' "$BOOTSTRAP_DOMAIN" "$WAKE_LABEL"
printf '  tail -f %s\n' "$INTERVAL_STDOUT_PATH"
printf '  tail -f %s\n' "$WAKE_STDOUT_PATH"
printf '\n'
printf 'To uninstall:\n'
printf '  launchctl bootout %s %s\n' "$BOOTSTRAP_DOMAIN" "$INTERVAL_PLIST_PATH"
printf '  launchctl bootout %s %s\n' "$BOOTSTRAP_DOMAIN" "$WAKE_PLIST_PATH"
printf '  rm -f %s %s\n' "$INTERVAL_PLIST_PATH" "$WAKE_PLIST_PATH"
